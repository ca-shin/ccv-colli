{
  "name": "ccvcolli-web",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "dev:5001": "sh scripts/run-dev-5001.sh",
    "server:dev": "NODE_ENV=development tsx server/index.ts",
    "web:dev": "EXPO_PUBLIC_DOMAIN=localhost:5001 npx expo start --localhost --web --port 8081",
    "web:build": "npx expo export --platform web",
    "build": "npm run web:build && npm run server:build",
    "preview:5001": "sh scripts/run-preview-5001.sh",
    "server:build": "npx --yes esbuild server/index.ts --platform=node --packages=external --bundle --format=cjs --outdir=server_dist",
    "server:prod": "NODE_ENV=production node server_dist/index.js",
    "start": "npm run web:dev",
    "lint": "npx expo lint",
    "lint:fix": "npx expo lint --fix"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.0",
    "@expo-google-fonts/montserrat": "^0.4.2",
    "@expo-google-fonts/playfair-display": "^0.4.2",
    "@expo-google-fonts/spectral": "^0.4.1",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-query": "^5.83.0",
    "compression": "^1.8.1",
    "esbuild": "^0.25.12",
    "expo": "~54.0.27",
    "expo-constants": "~18.0.11",
    "expo-font": "~14.0.10",
    "expo-linking": "~8.0.10",
    "expo-router": "~6.0.17",
    "express": "^5.0.1",
    "http-proxy-middleware": "^3.0.5",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "tsx": "^4.20.6"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.0",
    "@types/react": "~19.1.10",
    "babel-plugin-react-compiler": "^19.0.0-beta-e993439-20250117",
    "eslint": "^9.31.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "uuid": "^11.1.1"
  },
  "private": true
}
